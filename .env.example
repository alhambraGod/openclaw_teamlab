# =============================================
# OpenClaw TeamLab — PI Team Management System
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Instance Identity
PROJECT_NAME=openclaw_teamlab
INSTANCE_NAME=openclaw_teamlab
ENV=prod

# LLM Inference (OpenAI-compatible API)
LLM_BASE_URL=http://your-llm-server:port/v1
LLM_API_KEY=your-api-key
LLM_MODEL=your-model-name
LLM_FAST_MODEL=your-fast-model-name
LLM_MAX_TOKENS=65536

# Gateway
HOST=0.0.0.0
PORT=10301
DEBUG=false
SECRET_KEY=change-me-to-a-random-string

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=openclaw_teamlab

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=3
REDIS_PREFIX=openclaw_teamlab:prod

# Feishu / Lark (from Feishu Open Platform)
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# Email (SMTP) — optional, for digest notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USER=your-email@example.com
SMTP_FROM=your-email@example.com
SMTP_AUTH_CODE=your-smtp-auth-code

# Worker Pool
WORKER_MIN=3
WORKER_MAX=20
WORKER_PORT_BASE=10310

# Scheduler
SCHEDULER_PORT=10302

# Logging
LOG_LEVEL=INFO
