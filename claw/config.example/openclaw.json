{
  "gateway": {
    "port": 10300,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:10300"
      ],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "your_token_here"
    },
    "tailscale": {
      "mode": "off"
    }
  },
  "models": {
    "providers": {
      "openai-proxy": {
        "baseUrl": "http://YOUR_LLM_PROXY/v1",
        "apiKey": "sk-YOUR_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "gemini-3.1-pro-preview",
            "name": "Gemini 3.1 Pro"
          }
        ]
      }
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "domain": "feishu",
      "connectionMode": "websocket",
      "streaming": false,
      "blockStreaming": false,
      "accounts": {
        "main": {
          "appId": "cli_YOUR_FEISHU_APP_ID",
          "appSecret": "YOUR_FEISHU_APP_SECRET",
          "botName": "C-Si TeamLab"
        },
        "default": {
          "dmPolicy": "open",
          "groupPolicy": "open",
          "allowFrom": [
            "*"
          ]
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "memorySearch": {
        "enabled": false
      }
    }
  },
  "env": {
    "TEAMLAB_BASE_URL": "http://127.0.0.1:10301"
  }
}